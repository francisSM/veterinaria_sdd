{
  "name": "veterinaria_sdd",
  "version": "1.0.0",
  "description": "Sistema de Gestión Integral para Clínica Veterinaria - Fabrica L5",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "dev:front": "vite",
    "test": "jest --forceExit --passWithNoTests",
    "lint": "eslint src/**/*.ts --ext .ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "jest": "^29.7.0",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "supertest": "^6.3.4",
    "tailwindcss": "^4.3.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^8.1.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "passWithNoTests": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
